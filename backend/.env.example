# ── Research APIs ─────────────────────────────────────────────────────────────
# Optional — get a free key at https://www.semanticscholar.org/product/api
# Without a key, Semantic Scholar rate-limits to ~1 req/sec; with a key ~100 req/sec
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── TTS / STT ─────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── Media & Research ──────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here
PEXELS_API_KEY=your_pexels_api_key_here

# ── Specialized AI ────────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL=your_mongodb_connection_string_here

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# ── Email / SMTP (for Forgot Password) ────────────────────────────────────────
# Gmail example: enable "App Passwords" in your Google account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# NOTE: Wikipedia and DuckDuckGo search do not require API keys.
